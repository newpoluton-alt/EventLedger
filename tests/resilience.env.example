# Black-box API configuration
EVENTLEDGER_BASE_URL=http://localhost:8080
EVENTLEDGER_API_KEY=local-development-key
EVENTLEDGER_SOURCE_ACCOUNT_ID=00000000-0000-0000-0000-000000000001
EVENTLEDGER_DESTINATION_ACCOUNT_ID=00000000-0000-0000-0000-000000000002
EVENTLEDGER_CURRENCY=EUR
EVENTLEDGER_PAYMENT_AMOUNT=1.00
EVENTLEDGER_REQUEST_TIMEOUT_SECONDS=5
EVENTLEDGER_RECOVERY_TIMEOUT_SECONDS=45

# Explicit opt-in flags
EVENTLEDGER_RUN_INTEGRATION=1
EVENTLEDGER_RUN_FAULT_TESTS=1

# Commands are JSON arrays. They are executed directly, never through a shell.
# Adjust service names to match the local orchestrator before enabling fault tests.
EVENTLEDGER_CRASH_DELAY_SECONDS=0.05
EVENTLEDGER_FAULT_COMMAND_TIMEOUT_SECONDS=90
EVENTLEDGER_APP_CRASH_COMMAND='["docker","compose","kill","app"]'
EVENTLEDGER_APP_START_COMMAND='["docker","compose","up","-d","app"]'
EVENTLEDGER_KAFKA_STOP_COMMAND='["docker","compose","stop","kafka"]'
EVENTLEDGER_KAFKA_START_COMMAND='["docker","compose","start","kafka"]'
EVENTLEDGER_POSTGRES_STOP_COMMAND='["docker","compose","stop","postgres"]'
EVENTLEDGER_POSTGRES_START_COMMAND='["docker","compose","start","postgres"]'
