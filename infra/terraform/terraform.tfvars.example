aws_region         = "eu-central-1"
availability_zones = ["eu-central-1a", "eu-central-1b", "eu-central-1c"]
environment        = "prod"

certificate_arn             = "arn:aws:acm:eu-central-1:123456789012:certificate/00000000-0000-0000-0000-000000000000"
domain_name                 = "api.eventledger.example"
hosted_zone_id              = "Z00000000000000000000"
image_tag                   = "sha-0123456789abcdef"
db_final_snapshot_identifier = "eventledger-prod-postgres-final-20260723"
database_app_secret_arn      = "arn:aws:secretsmanager:eu-central-1:123456789012:secret:eventledger-prod/database-ABC123"
database_app_kms_key_arn     = "arn:aws:kms:eu-central-1:123456789012:key/11111111-1111-1111-1111-111111111111"

msk_scram_secret_arn         = "arn:aws:secretsmanager:eu-central-1:123456789012:secret:AmazonMSK_eventledger-ABC123"
msk_scram_kms_key_arn        = "arn:aws:kms:eu-central-1:123456789012:key/00000000-0000-0000-0000-000000000000"
kafka_username               = "eventledger"
kafka_acl_bootstrap_complete = false

redis_final_snapshot_identifier = "eventledger-prod-redis-final-20260723"
alarm_notification_arns         = ["arn:aws:sns:eu-central-1:123456789012:eventledger-operations"]

# Supply the token outside committed files:
# export TF_VAR_redis_auth_token="$(openssl rand -hex 32)"
# During rotation only:
# export TF_VAR_redis_next_auth_token="$(openssl rand -hex 32)"
